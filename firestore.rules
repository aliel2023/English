rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================================================================
    // HELPER FUNCTIONS
    // ================================================================
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    function isValidEmail(email) {
      return email is string && email.matches('.*@.*\\..*');
    }

    // ================================================================
    // USERS COLLECTION
    // ================================================================
    match /users/{userId} {
      // Öz profilini oxuya bilər, admin hər kəsi oxuya bilər
      allow read: if isOwner(userId) || isAdmin();

      // Yeni profil yaratmaq
      allow create: if isOwner(userId)
        && isValidString(request.resource.data.name, 2, 100)
        && isValidEmail(request.resource.data.email)
        && (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email == 'englishaliel@gmail.com'))
        && request.resource.data.keys().hasAll(['name','email','level','role','createdAt']);

      // Admin hər şeyi güncəlləyə bilər (premium vermək daxil)
      // İstifadəçi yalnız icazə verilmiş sahələri güncəlləyə bilər
      allow update: if isAdmin() || (isOwner(userId)
        // role sahəsini dəyişdirə BİLMƏZ
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        // email-i dəyişdirə BİLMƏZ  
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['email']))
        // premium sahəsini dəyişdirə BİLMƏZ
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['premium']))
      );

      // Silmə yalnız admin
      allow delete: if isAdmin();
    }

    // ================================================================
    // LEADS COLLECTION
    // ================================================================
    match /leads/{leadId} {
      allow create: if isAuth()
        && isValidString(request.resource.data.name, 2, 100)
        && isValidEmail(request.resource.data.email)
        && request.resource.data.keys().hasAll(['name','email','createdAt']);

      allow read: if isAdmin();

      // Audit log — heç kəs dəyişdirə bilməz
      allow update, delete: if false;
    }

    // ================================================================
    // LESSONS COLLECTION
    // ================================================================
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ================================================================
    // PROGRESS COLLECTION
    // ================================================================
    match /progress/{progressId} {
      // Yaratılırkən: request.resource.data istifadə et
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      // Oxumaq: öz məlumatı və ya admin
      allow read: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ================================================================
    // AI USAGE TRACKING (rate limit per user)
    // ================================================================
    match /ai_usage/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
    }

    // ================================================================
    // REPORTS / FEEDBACK
    // ================================================================
    match /reports/{reportId} {
      allow create: if isAuth()
        && isValidString(request.resource.data.message, 5, 500);
      allow read, update, delete: if isAdmin();
    }

    // ================================================================
    // DEFAULT: Heç bir koleksiyaya icazə yoxdur
    // ================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
